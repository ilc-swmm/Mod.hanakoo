{
    "prefix": "h!",
    "default_settings": {
        "automod_enabled": false,
        "spam_detection": false,
        "profanity_filter": false,
        "max_warnings": 5,
        "warning_actions": {
            "1": "warn",
            "2": "timeout",
            "3": "ban"
        },
        "timeout_duration": 300,
        "log_channel": null,
        "welcome_enabled": false,
        "welcome_channel": null,
        "welcome_message": "Welcome to {guild}, {user}!"
    },
    "blacklist_words": [
        "",
        "",
        "",
        ""
    ],
    "spam_thresholds": {
        "messages_per_minute": 100,
        "duplicate_messages": 5,
        "mention_limit": 10,
        "emoji_limit": 15
    },
    "moderation_roles": [
        "Moderator",
        "Admin",
        "Staff"
    ],
    "immune_roles": [
        "Admin",
        "Owner",
        "Bot"
    ],
    "logging": {
        "level": "INFO",
        "format": "[%(asctime)s] [%(levelname)s] %(name)s: %(message)s",
        "file": "bot.log"
    }
}
